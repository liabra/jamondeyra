# Copiez ce fichier en .env et remplissez les valeurs.
# Ne committez jamais .env dans git.

# Chaîne aléatoire longue (min 32 caractères)
# Générez-en une avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changez-moi-en-une-chaine-aleatoire-longue

# Hash bcrypt du mot de passe admin
# Générez-le avec : node scripts/setup.js
ADMIN_PASSWORD_HASH=

# Environnement (production active les cookies sécurisés)
NODE_ENV=production
